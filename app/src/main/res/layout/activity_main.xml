<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/rootLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/titleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Simulador de Provas"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingBottom="8dp" />

        <TextView
            android:id="@+id/dbInfoText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Banco de dados interno será usado automaticamente."
            android:paddingBottom="8dp" />

        <TextView
            android:id="@+id/totalQuestoesText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Total de questões: -" />

        <Button
            android:id="@+id/startSimuladoButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Iniciar simulado"
            android:layout_marginTop="16dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:background="#CCCCCC" />

        <LinearLayout
            android:id="@+id/questionsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="16dp" />

        <Button
            android:id="@+id/finishSimuladoButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Finalizar simulado"
            android:layout_marginTop="16dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/resultText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text=""
            android:textIsSelectable="true" />

    </LinearLayout>

</ScrollView>

